#!/bin/bash

date
export PATH=$PATH:/sibcb2/wuweilab2/liangyu/Software/piPipes
source /sibcb/program/install/python-3.8/profile
source /sibcb/program/install/r-3.6.1/profile

echo $sample
piPipes rna -l ../fixed.fastq/${sample}_cutadapt_R1.fastq.gz -r ../fixed.fastq/${sample}_cutadapt_R2.fastq.gz -c 12  -g dm6 -o ${sample}_out

