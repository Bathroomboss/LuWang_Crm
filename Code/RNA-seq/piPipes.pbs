#  -o 20240923-shwhite.vs.shHis1 -A shwhite -B shHis1 -c 12 -g dm6 
# piPipes rna2 -a 20240923-LYN-pupa4d-shwhite_RNA-seq_rep1_out -b 20240923-LYN-pupa4d-shHis1_RNA-seq_rep1_out -o 20240923-shwhite.vs.shHis1_rep1 -A shwhite_rep1 -B shHis1_rep1 -c 12 -g dm6
# piPipes rna2 -a 20240923-LYN-pupa4d-shwhite_RNA-seq_rep2_out -b 20240923-LYN-pupa4d-shHis1_RNA-seq_rep2_out -o 20240923-shwhite.vs.shHis1_rep2 -A shwhite_rep2 -B shHis1_rep2 -c 12 -g dm6

